# 数据存储配置
# DATA_DIR: 数据存储目录，支持环境变量扩展如 ${HOME}
DATA_DIR=${HOME}/Data/ntchat_bot

# 日志配置
# LOG_LEVEL: 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=DEBUG

# 微信自动回复配置
# WECHAT_AUTO_REPLY_ENABLED: 是否启用自动回复功能
WECHAT_AUTO_REPLY_ENABLED=true

# WECHAT_GROUP_REPLY_ENABLED: 是否启用群消息自动回复
WECHAT_GROUP_REPLY_ENABLED=true

# WECHAT_CONTACT_REPLY_ENABLED: 是否启用联系人消息自动回复
WECHAT_CONTACT_REPLY_ENABLED=true

# 数据存储配置
# MESSAGE_SAVE_ENABLED: 是否保存消息到数据库
MESSAGE_SAVE_ENABLED=true

# CONTACT_SYNC_ENABLED: 是否同步联系人信息到数据库
CONTACT_SYNC_ENABLED=true

# CHATROOM_SYNC_ENABLED: 是否同步群信息到数据库
CHATROOM_SYNC_ENABLED=true